JWT_SECRET=change-me-to-a-long-random-string

# Access token (short) + refresh token (long)
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Set to production in go-live; enforces strong JWT_SECRET
NODE_ENV=development

PORT=3001

CORS_ORIGIN=http://localhost:3000

# Frontend (create frontend/.env from frontend/.env.example)
# REACT_APP_API_BASE=http://localhost:3001

# Run npm run hash-passwords before go-live (plain-text passwords are rejected)



# District tenant (change for another district deployment)

DISTRICT_ID=tirap



# SQL Server (optional — defaults match local SQLEXPRESS)

DB_SERVER=localhost

DB_INSTANCE=SQLEXPRESS

DB_NAME=DistrictDB4

DB_USER=sa

DB_PASSWORD=password

